# Copia este archivo como .env para desarrollo local y para el script seed.py
# En producción (Vercel) configura estas variables en Settings → Environment Variables

# URL de conexión a PostgreSQL (Supabase)
# Obtenla en: Supabase → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Clave secreta para firmar los tokens JWT
# Genera una segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=una_clave_muy_segura_aqui
